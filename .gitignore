# =============================================================================
# Hyperdimensional Pattern Decoder — .gitignore
# Root: Python / FastAPI  |  frontend/: Node.js / Vite / React
# =============================================================================


# =============================================================================
# 1. PYTHON / FASTAPI ENVIRONMENT
# =============================================================================

# Compiled bytecode and cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# Package build artefacts
*.egg-info/
*.egg
MANIFEST
dist/
build/

# Virtual environments (all common names)
venv/
.venv/
env/
ENV/
.env/
.ENV/

# pip / setuptools / wheel
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Runtime logs
*.log

# Local secrets / environment variables (never commit credentials)
.env
.env.local
.env.*.local


# =============================================================================
# 2. NODE.JS / REACT / VITE FRONTEND ENVIRONMENT
# =============================================================================

# Dependency directories — matched at any depth
node_modules/
frontend/node_modules/
jspm_packages/

# Frontend environment files
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Production build output
frontend/dist/
frontend/build/

# Vite / bundler cache
frontend/.vite/
frontend/.parcel-cache/
.cache/

# npm / yarn / pnpm lock files generated by CI (keep local lock files)
# npm-debug.log and yarn-error.log are noise
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Optional npm cache
.npm

# Optional eslint cache
.eslintcache

# Storybook output
storybook-static/


# =============================================================================
# 3. IDE AND EDITOR FILES
# =============================================================================

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
out/

# Visual Studio Code
.vscode/
*.code-workspace

# Vim / Emacs / Nano swap files
*.swp
*.swo
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace


# =============================================================================
# 4. OPERATING SYSTEM FILES
# =============================================================================

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# Linux
*~


# =============================================================================
# 5. PROJECT-SPECIFIC EXCLUSIONS
# =============================================================================

# User-uploaded test images — never commit binary uploads to the repo
uploads/

# Local development overrides
*.local.py
local_settings.py
